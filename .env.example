
# ── Deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...

# ── RPC endpoints ─────────────────────────────────────────────────────────────
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
REACTIVE_NETWORK_RPC=https://kopli-rpc.rkt.ink

# ── Unichain Sepolia — core addresses ─────────────────────────────────────────
# Uniswap v4 PoolManager on Unichain Sepolia
POOL_MANAGER=0x00B036B58a818B1BC34d502D3fE730Db729e62AC

# ETH/USD Chainlink price feed on Unichain Sepolia
# If Chainlink is not live on Unichain Sepolia, deploy a mock feed and use its address
CHAINLINK_FEED=0x0000000000000000000000000000000000000000

# The ERC-20 token the vault will hold and pay out (typically WETH or USDC)
PAYOUT_TOKEN=0x0000000000000000000000000000000000000000

# Pool tokens
TOKEN0=0x0000000000000000000000000000000000000000   # lower address (v4 sorts currency0 < currency1)
TOKEN1=0x0000000000000000000000000000000000000000

# ── Pool parameters ────────────────────────────────────────────────────────────
# Unichain Sepolia chain ID
DEST_CHAIN_ID=1301

# Pool tick spacing — 60 corresponds to the 0.30% fee tier
TICK_SPACING=60

# Hook base fee in v4 pips (1e6 = 100%). 3000 = 0.30%
BASE_FEE_BPS=3000

# Decimal adjustment for _sqrtPriceToPrice1e18():
#   = 10^(token0Decimals - token1Decimals + 18)
#   WETH(18)/USDC(6): 10^(18-6+18) = 10^30 = 1000000000000000000000000000000
DECIMAL_ADJUSTMENT=1000000000000000000000000000000

# Initial sqrtPriceX96 for pool initialisation
#   1:1 ratio:         79228162514264337593543950336
#   ~$2000 ETH/USDC:   use https://uniswapv3book.com/tools/sqrtprice or calculate offline
INIT_SQRT_PRICE_X96=79228162514264337593543950336

# ── Oracle parameters ──────────────────────────────────────────────────────────
# sqrtOracleDivisor = sqrt(10^(chainlinkDecimals + token0Decimals - token1Decimals))
#   ETH/USD feed (8 dec) with WETH(18)/USDC(6): sqrt(10^(8+18-6)) = sqrt(10^20) = 1e10
SQRT_ORACLE_DIVISOR=10000000000

# Oracle manipulation detection threshold in bps (200 = 2%)
MANIPULATION_THRESHOLD_BPS=200

# Initial Chainlink oracle price to seed TridentReactive before the first AnswerUpdated event
# For ETH/USD at $2000 with 8 decimal Chainlink feed: 2000 * 1e8 = 200000000000
INITIAL_ORACLE_PRICE=200000000000

# ── Post-deploy: fill these in after running Deploy.s.sol ─────────────────────
TRIDENT_HOOK_ADDRESS=0x0000000000000000000000000000000000000000
REACTIVE_ADAPTER_ADDRESS=0x0000000000000000000000000000000000000000

# ── Post-deploy: fill this in after running DeployReactive.s.sol ──────────────
REACTIVE_ORIGIN_ADDRESS=0x0000000000000000000000000000000000000000
